# Comparing LASSO, Ridge, and Elastic Net

```{r compare-methods}
set.seed(123)

# LASSO (alpha = 1)
cv_lasso <- cv.glmnet(x_train, y_train, alpha = 1)

# Ridge (alpha = 0)
cv_ridge <- cv.glmnet(x_train, y_train, alpha = 0)

# Elastic Net (alpha = 0.5)
cv_enet <- cv.glmnet(x_train, y_train, alpha = 0.5)

# Compare
comparison <- data.frame(
  Method = c("LASSO (α=1)", "Elastic Net (α=0.5)", "Ridge (α=0)"),
  Lambda_min = c(cv_lasso$lambda.min, cv_enet$lambda.min, cv_ridge$lambda.min),
  CV_Error = c(
    min(cv_lasso$cvm),
    min(cv_enet$cvm),
    min(cv_ridge$cvm)
  ),
  Nonzero_Coefs = c(
    sum(coef(cv_lasso, s = "lambda.min")[-1] != 0),
    sum(coef(cv_enet, s = "lambda.min")[-1] != 0),
    sum(coef(cv_ridge, s = "lambda.min")[-1] != 0)
  )
)

knitr::kable(comparison, digits = 4, caption = "Comparison of Regularization Methods")
```

```{r compare-coefs-plot, fig.cap="Coefficient estimates across methods"}
coef_compare <- data.frame(
  Predictor = colnames(X),
  True = true_betas,
  LASSO = as.numeric(coef(cv_lasso, s = "lambda.min")[-1]),
  Ridge = as.numeric(coef(cv_ridge, s = "lambda.min")[-1]),
  Elastic_Net = as.numeric(coef(cv_enet, s = "lambda.min")[-1])
)

coef_compare_long <- tidyr::pivot_longer(
  coef_compare,
  cols = c(True, LASSO, Ridge, Elastic_Net),
  names_to = "Method",
  values_to = "Coefficient"
)

ggplot(coef_compare_long, aes(x = reorder(Predictor, -abs(Coefficient)), y = Coefficient, fill = Method)) +
  geom_bar(stat = "identity", position = position_dodge(width = 0.7), width = 0.6) +
  coord_flip() +
  scale_fill_manual(values = c("#e74c3c", "#3498db", "#e67e22", "#2c3e50")) +
  labs(
    title = "Coefficient Estimates: LASSO vs Ridge vs Elastic Net",
    subtitle = "Notice Ridge never sets coefficients to exactly zero",
    x = NULL,
    y = "Coefficient Value"
  ) +
  theme_minimal(base_size = 13) +
  theme(legend.position = "top")
```

