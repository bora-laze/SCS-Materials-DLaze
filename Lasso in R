# Applying LASSO in R {.tabset}

## Setup

```{r load-packages}
# Install packages if needed (uncomment the lines below)
# install.packages("glmnet")
# install.packages("caret")
# install.packages("psych")

library(glmnet)   # Core LASSO implementation
library(caret)    # For data splitting and preprocessing
library(psych)    # For simulating psychology-like data
library(ggplot2)  # For plotting
```

## Simulating Psychology Data

For this demonstration, we'll simulate a dataset resembling a psychology study: predicting therapy outcome from personality traits, cognitive measures, and demographic variables.

```{r simulate-data}
set.seed(42)
n <- 200  # Sample size (typical for psychology)
p <- 20   # Number of predictors

# Simulate correlated predictors (common in psychology)
Sigma <- matrix(0.3, nrow = p, ncol = p)
diag(Sigma) <- 1
X <- MASS::mvrnorm(n, mu = rep(0, p), Sigma = Sigma)

# Name the predictors
colnames(X) <- c(
  paste0("Personality_", 1:8),
  paste0("Cognitive_", 1:6),
  paste0("Demographic_", 1:4),
  "Social_Support",
  "Treatment_Adherence"
)

# True model: only 5 of 20 predictors actually matter
true_betas <- c(1.5, -0.8, 0, 0, 0.6, 0, 0, 0,   # Personality
                1.2, 0, 0, 0, -0.9, 0,              # Cognitive
                0, 0, 0, 0,                           # Demographic
                0, 0)                                 # Social/Adherence

# Generate outcome (therapy improvement score)
y <- X %*% true_betas + rnorm(n, sd = 2)

# Combine into a data frame
df <- data.frame(Therapy_Outcome = y, X)

cat("Dataset dimensions:", dim(df), "\n")
cat("True non-zero predictors:", sum(true_betas != 0), "out of", p, "\n")
```

## Preparing the Data

```{r data-prep}
# glmnet requires a matrix of predictors and a response vector
# Split into training (70%) and test (30%) sets
set.seed(123)
train_idx <- sample(1:n, size = 0.7 * n)
test_idx  <- setdiff(1:n, train_idx)

x_train <- X[train_idx, ]
y_train <- y[train_idx]
x_test  <- X[test_idx, ]
y_test  <- y[test_idx]

cat("Training set:", nrow(x_train), "observations\n")
cat("Test set:    ", nrow(x_test), "observations\n")
```

## Fitting LASSO with Cross-Validation

```{r fit-lasso}
set.seed(123)  # Important: CV folds are random
cv_fit <- cv.glmnet(
  x      = x_train,
  y      = y_train,
  alpha  = 1,       # alpha = 1 → LASSO; alpha = 0 → Ridge
  nfolds = 10       # 10-fold cross-validation
)

# Plot the cross-validation curve
plot(cv_fit, main = "LASSO Cross-Validation Curve")
```

### Understanding the CV Plot

- The **left dashed line** marks `lambda.min` — the $\lambda$ that minimizes cross-validated error
- The **right dashed line** marks `lambda.1se` — the largest $\lambda$ within 1 SE of the minimum (produces a sparser model)
- The numbers along the top indicate how many predictors are non-zero at each $\lambda$

```{r lambda-values}
cat("lambda.min:", cv_fit$lambda.min, "\n")
cat("lambda.1se:", cv_fit$lambda.1se, "\n")
```

## Examining the Coefficients

```{r coefficients}
# Coefficients at lambda.min (less sparse, better fit)
coef_min <- coef(cv_fit, s = "lambda.min")
cat("=== Coefficients at lambda.min ===\n")
cat("Non-zero predictors:", sum(coef_min[-1] != 0), "out of", p, "\n\n")

# Coefficients at lambda.1se (sparser, more parsimonious)
coef_1se <- coef(cv_fit, s = "lambda.1se")
cat("=== Coefficients at lambda.1se ===\n")
cat("Non-zero predictors:", sum(coef_1se[-1] != 0), "out of", p, "\n")
```

```{r coef-comparison-plot, fig.cap="Comparison of true coefficients vs LASSO estimates"}
# Build comparison data frame
coef_df <- data.frame(
  Predictor = colnames(X),
  True = true_betas,
  LASSO_min = as.numeric(coef_min[-1]),
  LASSO_1se = as.numeric(coef_1se[-1])
)

# Reshape for plotting
coef_long <- tidyr::pivot_longer(
  coef_df,
  cols = c(True, LASSO_min, LASSO_1se),
  names_to = "Method",
  values_to = "Coefficient"
)
coef_long$Method <- factor(coef_long$Method,
  levels = c("True", "LASSO_min", "LASSO_1se"),
  labels = c("True Coefficients", "LASSO (lambda.min)", "LASSO (lambda.1se)")
)

ggplot(coef_long, aes(x = reorder(Predictor, -abs(Coefficient)), y = Coefficient, fill = Method)) +
  geom_bar(stat = "identity", position = position_dodge(width = 0.7), width = 0.6) +
  coord_flip() +
  scale_fill_manual(values = c("#2c3e50", "#3498db", "#e74c3c")) +
  labs(
    title = "True vs. LASSO-Estimated Coefficients",
    x = NULL,
    y = "Coefficient Value"
  ) +
  theme_minimal(base_size = 13) +
  theme(legend.position = "top")
```

## Coefficient Path Plot

```{r coef-path, fig.cap="LASSO coefficient paths as lambda increases"}
fit_full <- glmnet(x_train, y_train, alpha = 1)
plot(fit_full, xvar = "lambda", label = TRUE, main = "LASSO Coefficient Paths")
abline(v = log(cv_fit$lambda.min), lty = 2, col = "blue")
abline(v = log(cv_fit$lambda.1se), lty = 2, col = "red")
legend("topright", legend = c("lambda.min", "lambda.1se"),
       col = c("blue", "red"), lty = 2, cex = 0.8)
```

## Evaluating Prediction Performance

```{r prediction}
# Predictions on test set
pred_lasso_min <- predict(cv_fit, newx = x_test, s = "lambda.min")
pred_lasso_1se <- predict(cv_fit, newx = x_test, s = "lambda.1se")

# Also fit OLS for comparison
ols_fit <- lm(y_train ~ x_train)
pred_ols <- cbind(1, x_test) %*% coef(ols_fit)

# Calculate RMSE and R-squared
rmse <- function(actual, predicted) sqrt(mean((actual - predicted)^2))
rsq  <- function(actual, predicted) 1 - sum((actual - predicted)^2) / sum((actual - mean(actual))^2)

results <- data.frame(
  Method = c("OLS", "LASSO (lambda.min)", "LASSO (lambda.1se)"),
  RMSE = c(
    rmse(y_test, pred_ols),
    rmse(y_test, pred_lasso_min),
    rmse(y_test, pred_lasso_1se)
  ),
  R_squared = c(
    rsq(y_test, pred_ols),
    rsq(y_test, pred_lasso_min),
    rsq(y_test, pred_lasso_1se)
  ),
  Predictors_Used = c(
    p,
    sum(coef_min[-1] != 0),
    sum(coef_1se[-1] != 0)
  )
)

knitr::kable(results, digits = 3, caption = "Prediction Performance on Test Set")
```

